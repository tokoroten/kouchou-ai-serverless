    "ml-kmeans": "^6.0.0",
    "papaparse": "^5.5.3",
    "plotly.js-dist-min": "^3.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "seedrandom": "^3.0.5",
    "umap-js": "^1.4.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/papaparse": "^5.3.16",
